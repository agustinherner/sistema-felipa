generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  ADMIN
  VENDEDOR
}

enum TipoMovimiento {
  INGRESO
  VENTA
  AJUSTE_ROTURA
  AJUSTE_ROBO
  AJUSTE_CONTEO
  DEVOLUCION
}

model HealthCheck {
  id        Int      @id @default(autoincrement())
  checkedAt DateTime @default(now())
}

model Sucursal {
  id        String   @id @default(cuid())
  nombre    String   @unique
  direccion String?
  activa    Boolean  @default(true)
  creadaEn  DateTime @default(now())

  usuarios    Usuario[]
  stocks      Stock[]
  ventas      Venta[]
  movimientos MovimientoStock[]
}

model Categoria {
  id          String  @id @default(cuid())
  nombre      String  @unique
  descripcion String?

  productos Producto[]
}

model Producto {
  id            String   @id @default(cuid())
  nombre        String
  descripcion   String?
  categoriaId   String?
  precioBase    Decimal  @db.Decimal(12, 2)
  costoBase     Decimal  @db.Decimal(12, 2)
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  categoria Categoria? @relation(fields: [categoriaId], references: [id])
  variantes Variante[]

  @@index([categoriaId])
}

model Variante {
  id            String   @id @default(cuid())
  productoId    String
  nombre        String
  atributos     Json?
  codigoBarras  String?  @unique
  precio        Decimal? @db.Decimal(12, 2)
  costo         Decimal? @db.Decimal(12, 2)
  activa        Boolean  @default(true)
  creadaEn      DateTime @default(now())
  actualizadaEn DateTime @updatedAt

  producto    Producto          @relation(fields: [productoId], references: [id])
  stocks      Stock[]
  itemsVenta  ItemVenta[]
  movimientos MovimientoStock[]

  @@index([productoId])
}

model Stock {
  id            String   @id @default(cuid())
  varianteId    String
  sucursalId    String
  cantidad      Int      @default(0)
  actualizadoEn DateTime @default(now())

  variante Variante @relation(fields: [varianteId], references: [id])
  sucursal Sucursal @relation(fields: [sucursalId], references: [id])

  @@unique([varianteId, sucursalId])
  @@index([sucursalId])
}

model Usuario {
  id            String   @id @default(cuid())
  email         String   @unique
  nombre        String
  rol           Rol
  passwordHash  String?
  sucursalId    String?
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  sucursal    Sucursal?         @relation(fields: [sucursalId], references: [id])
  ventas      Venta[]
  movimientos MovimientoStock[]

  @@index([sucursalId])
}

model Venta {
  id              String   @id @default(cuid())
  codigoCorto     String   @unique
  sucursalId      String
  usuarioId       String
  subtotal        Decimal  @db.Decimal(12, 2)
  descuentoTotal  Decimal  @default(0) @db.Decimal(12, 2)
  total           Decimal  @db.Decimal(12, 2)
  metodosPago     Json
  whatsappCliente String?
  creadaEn        DateTime @default(now())

  sucursal    Sucursal          @relation(fields: [sucursalId], references: [id])
  usuario     Usuario           @relation(fields: [usuarioId], references: [id])
  items       ItemVenta[]
  movimientos MovimientoStock[]

  @@index([sucursalId, creadaEn])
  @@index([usuarioId])
}

model ItemVenta {
  id             String  @id @default(cuid())
  ventaId        String
  varianteId     String
  cantidad       Int
  precioUnitario Decimal @db.Decimal(12, 2)
  subtotal       Decimal @db.Decimal(12, 2)

  venta    Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  variante Variante @relation(fields: [varianteId], references: [id])

  @@index([ventaId])
  @@index([varianteId])
}

model MovimientoStock {
  id         String         @id @default(cuid())
  varianteId String
  sucursalId String
  tipo       TipoMovimiento
  cantidad   Int
  motivo     String?
  usuarioId  String
  ventaId    String?
  creadoEn   DateTime       @default(now())

  variante Variante @relation(fields: [varianteId], references: [id])
  sucursal Sucursal @relation(fields: [sucursalId], references: [id])
  usuario  Usuario  @relation(fields: [usuarioId], references: [id])
  venta    Venta?   @relation(fields: [ventaId], references: [id])

  @@index([varianteId])
  @@index([sucursalId, creadoEn])
  @@index([ventaId])
}
